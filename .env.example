# Copy values from this file into:
# - backend/.env
# - agent/.env
# - frontend/frontend.env
#
# Do not commit real secrets.

MONGODB_URI=mongodb://127.0.0.1:27017/resumeforge
MONGODB_DB=resumeforge
JWT_SECRET=replace-with-a-long-random-secret

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
S3_BUCKET=hireforge-resumes
SQS_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/123456789012/hireforge-jobs

GROQ_API_KEY=replace-me
GROQ_MODEL=llama-3.3-70b-versatile

FRONTEND_URL=http://localhost:5173
PORT=3001
VITE_API_URL=http://localhost:3001/api
